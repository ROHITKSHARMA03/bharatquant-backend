# ─────────────────────────────────────────────────
#  BharatQuant Backend — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server
PORT=3001

# Upstox API Credentials (from account.upstox.com/apps)
UPSTOX_API_KEY=7af0cee5-0e42-47e0-904b-91f8da045b5f
UPSTOX_API_SECRET=YOUR_NEW_SECRET_AFTER_REGENERATING

# OAuth Redirect URI — must EXACTLY match what's set in Upstox app
# For local development:
REDIRECT_URI=http://localhost:3001/callback
# For Railway production (update after deploying):
# REDIRECT_URI=https://YOUR-APP.up.railway.app/callback

# Your Lovable frontend URL
FRONTEND_URL=https://bharat-trading.lovable.app

# Session secret (any random string, used for security)
SESSION_SECRET=bharatquant_super_secret_2026
